# VPS user to create and configure
VPS_USER=sai

# Optional SSH public key.
# Recommended: paste your laptop's ~/.ssh/id_ed25519.pub here.
# Example: SSH_PUBLIC_KEY=ssh-ed25519 AAAAC3NzaC1lZDI1NTE5AAAA... vps-infra
SSH_PUBLIC_KEY=

# Server timezone
SERVER_TIMEZONE=America/Los_Angeles

# Repo directory copied to the VPS user's home
REPO_NAME=docker-homelab

# Tailscale options
# Leave empty unless you want non-interactive auth later.
TAILSCALE_AUTH_KEY=
TAILSCALE_HOSTNAME=

# Cockpit port
COCKPIT_PORT=9090
